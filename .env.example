# YDM Project Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit the .env file with real secrets

# Database Configuration
# PostgreSQL connection string for the application database
DATABASE_URL=postgresql://localhost:5432/ydm_dev

# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication Configuration
# Secret API key for admin endpoints
# Generate a strong, random key for production
# Example: openssl rand -base64 32
ADMIN_API_KEY=your-admin-api-key-here

# Email Service Configuration
# SMTP server configuration for sending emails (contact forms, newsletter subscriptions)
# 
# Popular SMTP providers:
# - Gmail (development/low volume): smtp.gmail.com:587 with app password
# - SendGrid: smtp.sendgrid.net:587 with API key as password
# - Amazon SES: email-smtp.us-east-1.amazonaws.com:587 with AWS credentials
# - Mailgun: smtp.mailgun.org:587 with API key
# - Ethereal (testing): smtp.ethereal.email:587 (auto-generated credentials)

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false  # Set to true for port 465 (SSL), false for port 587 (STARTTLS)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password  # For Gmail, use an App Password (not account password)

# Email Addresses
EMAIL_FROM=noreply@yourdomain.com  # From address for outgoing emails
EMAIL_TO=admin@yourdomain.com     # Admin email for contact form notifications

# Security Configuration
# JWT secret for future token-based authentication
JWT_SECRET=your-jwt-secret-here

# CORS Configuration
# Allowed origins for cross-origin requests
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging Configuration
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Development vs Production
# Set to 'production' in production environment
NODE_ENV=development

# Graceful Shutdown Configuration
# Timeout in milliseconds for graceful shutdown (default: 30000)
SHUTDOWN_TIMEOUT=30000

# Production Configuration
# These are typically set in production deployment environments
# BASE_PATH: Base path for frontend routing (e.g., "/app" for subdirectory deployment)
BASE_PATH=/

# Database SSL Configuration (Production)
# Set to 'true' in production for secure database connections
DATABASE_SSL=false

# Performance Configuration
# Maximum number of database connections (default: 20)
DATABASE_POOL_MAX=20

# Request Timeout Configuration
# Timeout for HTTP requests in milliseconds (default: 30000)
REQUEST_TIMEOUT=30000
