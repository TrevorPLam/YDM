{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=3000 pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --maxWorkers=50%"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "cross-env": "^10.1.0",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "js-yaml": "^4.1.1",
    "nodemailer": "^6",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "jest": "^29.7.0",
    "pino-pretty": "^13",
    "supertest": "^7.0.0",
    "thread-stream": "3.1.0",
    "ts-jest": "^29.2.5"
  }
}
